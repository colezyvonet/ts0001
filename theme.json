{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"duotone": [],
			"gradients": [],
			"palette": [
				{
					"name": "Black",
					"slug": "black",
					"color": "#000000"
				},
				{
					"name": "Dark",
					"slug": "dark",
					"color": "#111111"
				},
				{
					"name": "Mid",
					"slug": "mid",
					"color": "#555555"
				},
				{
					"name": "Light",
					"slug": "light",
					"color": "#f5f5f5"
				},
				{
					"name": "Border",
					"slug": "border",
					"color": "#dddddd"
				},
				{
					"name": "White",
					"slug": "white",
					"color": "#ffffff"
				}
			],
			"link": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": []
		},
		"layout": {
			"contentSize": "740px",
			"wideSize": "1200px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Small",
					"size": "1rem",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "2rem",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "3rem",
					"slug": "large"
				},
				{
					"name": "Extra Large",
					"size": "5rem",
					"slug": "x-large"
				}
			],
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"blockGap": true,
			"padding": true,
			"margin": true
		},
		"typography": {
			"dropCap": false,
			"defaultFontSizes": false,
			"fluid": false,
			"fontFamilies": [
				{
					"fontFamily": "Helvetica, Arial, sans-serif",
					"name": "Helvetica",
					"slug": "primary"
				},
				{
					"fontFamily": "monospace",
					"name": "Monospace",
					"slug": "monospace"
				}
			],
			"fontSizes": [
				{
					"size": "0.85rem",
					"slug": "small",
					"name": "Small"
				},
				{
					"size": "1rem",
					"slug": "base",
					"name": "Base"
				},
				{
					"size": "1.25rem",
					"slug": "medium",
					"name": "Medium"
				},
				{
					"size": "1.75rem",
					"slug": "large",
					"name": "Large"
				},
				{
					"size": "2.5rem",
					"slug": "x-large",
					"name": "Extra Large"
				},
				{
					"size": "3.5rem",
					"slug": "xx-large",
					"name": "2XL"
				}
			],
			"lineHeight": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "#ffffff",
			"text": "#111111"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|primary",
			"fontSize": "var:preset|font-size|base",
			"lineHeight": "1.5"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large",
					"fontWeight": "700",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large",
					"fontWeight": "700",
					"lineHeight": "1.15"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "700"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"fontWeight": "700"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "700"
				}
			},
			"link": {
				"color": {
					"text": "#111111"
				},
				":hover": {
					"color": {
						"text": "#000000"
					}
				}
			},
			"button": {
				"color": {
					"background": "#111111",
					"text": "#ffffff"
				},
				"border": {
					"radius": "3px"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|primary",
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "600"
				},
				"spacing": {
					"padding": {
						"top": "0.5em",
						"right": "1.25em",
						"bottom": "0.5em",
						"left": "1.25em"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontWeight": "500"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/post-terms": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/code": {
				"color": {
					"background": "#f5f5f5",
					"text": "#111111"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|medium",
						"right": "var:preset|spacing|medium",
						"bottom": "var:preset|spacing|medium",
						"left": "var:preset|spacing|medium"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|monospace",
					"fontSize": "var:preset|font-size|small"
				}
			},
			"core/preformatted": {
				"color": {
					"background": "#f5f5f5",
					"text": "#111111"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|medium",
						"right": "var:preset|spacing|medium",
						"bottom": "var:preset|spacing|medium",
						"left": "var:preset|spacing|medium"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|monospace",
					"fontSize": "var:preset|font-size|small"
				}
			},
			"core/post-template": {
				"css": "& li:last-child:not(:only-child) > .wp-block-separator:last-child { display: none; }"
			},
			"core/details": {
				"css": ".wp-block-details summary { font-weight: 600 }"
			},
			"core/paragraph": {
				"css": "&.has-background { padding: var(--wp--preset--spacing--small) }"
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
